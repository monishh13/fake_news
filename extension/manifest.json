{
  "manifest_version": 3,
  "name": "AIVera Fact Checker",
  "version": "1.0",
  "description": "Select text and right-click to fact-check declarative claims using the local AIVera ML engine.",
  "permissions": ["contextMenus", "storage", "activeTab", "scripting"],
  "host_permissions": ["http://localhost:8081/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AIVera Analysis"
  }
}
